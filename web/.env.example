# Copy to `.env.local` (gitignored) and adjust as needed.

# Public — bundled into the browser. Never put real secrets in NEXT_PUBLIC_* vars.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional — company logos on the dashboard & ticker page (logo.dev).
# This is a *publishable* token (pk_...), designed for client-side use — not a secret.
# Leave blank to fall back to monogram avatars. Get one free at https://logo.dev.
NEXT_PUBLIC_LOGO_DEV_TOKEN=
